{
  "in": "in.jar",
  "out": "out.jar",
  "libs": "libs/",
  "dictionary": "abcdefghijklmnopqrstuvwxyzABCDEFGHIJKLMNOPQRSTUVWXYZ",
  "computeFrames": true,
  "transformers": {
    "renameFields": {
      "enabled": false,
      "shuffle": false
    },
    "renameMethods": {
      "enabled": false,
      "shuffle": true
    },
    "renameClasses": {
      "enabled": false,
      "randomize": true
    },
    "localNames": {
      "enabled": true
    },
    "methodSalting": {
      "enabled": false,
      "seedUselessMethods": false
    },
    "classSalting": {
      "enabled": false,
      "unifyAccess": true
    },
    "integerEncrypt": {
      "enabled": true
    },
    "encryptStrings": {
      "enabled": true,
      "translateConcat": true,
      "minLength": 2
    },
    "controlFlowFlatten": {
      "enabled": true,
      "useSalt": true
    },
    "controlFlowShuffle": {
      "enabled": true
    }
  }
}
