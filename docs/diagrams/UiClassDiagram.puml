@startuml
!include style.puml
skinparam arrowThickness 1.1
skinparam arrowColor UI_COLOR_T4
skinparam classBackgroundColor UI_COLOR

package UI <<Rectangle>>{
Class "<<interface>>\nUi" as Ui
Class "{abstract}\nUiPart" as UiPart
Class RoutePanel
Class UiManager
Class MainWindow
Class HelpWindow
Class ResultDisplay
Class CompanyListPanel
Class CompanyCard
Class DeliveryListPanel
Class DeliveryCard
Class RoutePanel
Class StatusBarFooter
Class CommandBox
Class DeliveryListPanel
Class DeliveryCard
}

package Model <<Rectangle>> {
Class HiddenModel #FFFFFF
}

package Logic <<Rectangle>> {
Class HiddenLogic #FFFFFF
}

Class HiddenOutside #FFFFFF
HiddenOutside ..> Ui

UiManager .left.|> Ui
UiManager -down-> "1" MainWindow
MainWindow *-down->  "1" CommandBox
MainWindow *-down-> "1" ResultDisplay
MainWindow *-down-> "1" CompanyListPanel
MainWindow *-down-> "1" DeliveryListPanel
MainWindow *-down-> "1" RoutePanel
MainWindow *-down-> "1" StatusBarFooter
MainWindow --> "0..1" HelpWindow
MainWindow *-down-> "1" DeliveryListPanel
MainWindow *-down-> "1" RoutePanel

CompanyListPanel -down-> "*" CompanyCard
DeliveryListPanel -down-> "*" DeliveryCard

MainWindow --|> UiPart

ResultDisplay --|> UiPart
CommandBox --|> UiPart
CompanyListPanel --|> UiPart
CompanyCard --|> UiPart
DeliveryListPanel --|> UiPart
DeliveryCard --|> UiPart
RoutePanel --|> UiPart
StatusBarFooter --|> UiPart
HelpWindow --|> UiPart
RoutePanel --|> UiPart
DeliveryCard --|> UiPart

DeliveryCard ...> Model
CompanyCard ...> Model
UiManager -right-> Logic
MainWindow -right-> Logic

CompanyListPanel -[hidden]left- HelpWindow
HelpWindow -[hidden]left- CommandBox
CommandBox -[hidden]left- ResultDisplay
ResultDisplay -[hidden]left- StatusBarFooter
MainWindow -[hidden]-|> UiPart
@enduml
