@startuml
!include style.puml
skinparam ArrowFontStyle plain

box Logic LOGIC_COLOR_T1
participant ":MainWindow" as MainWindow LOGIC_COLOR
participant ":LogicManager" as LogicManager LOGIC_COLOR
participant "r:RouteCommand" as RouteCommand LOGIC_COLOR
end box

box RoutePanel MODEL_COLOR_T1
participant ":RoutePanel" as RoutePanel MODEL_COLOR
end box
[-> MainWindow : executeCommand(route)
activate MainWindow

MainWindow -> LogicManager : parseCommand(route)
activate LogicManager

create RouteCommand
LogicManager -> RouteCommand : execute()
activate RouteCommand

RouteCommand --> LogicManager
deactivate RouteCommand

LogicManager --> MainWindow : r
deactivate LogicManager

destroy RouteCommand

MainWindow -> RoutePanel : planRoutesFor(Deliveries)
activate RoutePanel

RoutePanel --> MainWindow : commandResult
deactivate RoutePanel

[<--MainWindow
deactivate MainWindow
@enduml
